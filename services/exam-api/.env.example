PORT=3110
NODE_ENV=development

MONGODB_URI=mongodb://127.0.0.1:27017/exam_app
EXAM_JWT_SECRET=replace-with-a-32-char-secret-at-least
# Backward-compatible fallback for standalone deployments:
# JWT_SECRET=replace-with-a-32-char-secret-at-least
ADMIN_JWT_EXPIRES_IN=12h
USER_JWT_EXPIRES_IN=30d

WECHAT_APP_ID=wx_your_miniprogram_appid
WECHAT_APP_SECRET=your_miniprogram_app_secret

# Comma-separated list, for example:
# CORS_ORIGINS=https://admin.example.com,https://ops.example.com
CORS_ORIGINS=http://localhost:3110

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_DISPLAY_NAME=Super Admin
DEFAULT_ADMIN_PASSWORD=replace-with-a-strong-password

SCAN_LOGIN_QR_TTL_MS=300000
SCAN_LOGIN_TEMP_AUTH_CODE_TTL_MS=120000
SCAN_LOGIN_CLEANUP_TTL_MS=86400000
# QR code mode:
# - scheme: legacy ordinary QR code, scanned inside the mini program.
# - link: HTTPS ordinary-link QR code, requires non-personal mini program subject.
# - wxacode: official mini program code, suitable for personal mini programs.
SCAN_LOGIN_QR_CODE_MODE=scheme
# Optional for link mode: HTTPS link used inside the admin login QR code. Configure the same
# prefix in WeChat Mini Program Admin > Development > Development Management >
# Scan ordinary link QR code to open Mini Program, pointing to
# subpackages/user/scan-login/scan-login.
# SCAN_LOGIN_QR_LINK_BASE=https://admin.example.com/wx-login
# Optional for wxacode mode:
SCAN_LOGIN_WXACODE_PAGE=subpackages/user/scan-login/scan-login
SCAN_LOGIN_WXACODE_CHECK_PATH=true
# For testing an uploaded trial version before release:
# SCAN_LOGIN_WXACODE_CHECK_PATH=false
# SCAN_LOGIN_WXACODE_ENV_VERSION=trial
# SCAN_LOGIN_WXACODE_ENV_VERSION=release

ALIYUN_AI_CAPTCHA_ENABLED=true
ALIYUN_AI_CAPTCHA_REGION=cn
ALIYUN_AI_CAPTCHA_PREFIX=
ALIYUN_AI_CAPTCHA_SCENE_ID=e5isq0ly

# OpenAI-compatible AI analysis gateway. SUB2API_BASE_URL can be either
# https://your-domain.example, https://your-domain.example/v1, or a full
# /v1/chat/completions URL.
AI_ANALYSIS_ENABLED=true
SUB2API_BASE_URL=
SUB2API_API_KEY=
SUB2API_MODEL=gpt-4o-mini
AI_API_TIMEOUT_MS=30000
AI_MAX_TOKENS=1200
AI_RATE_LIMIT_MAX=10
AI_BATCH_MAX_PER_RUN=10
AI_BATCH_COOLDOWN_MS=60000
AI_GENERATION_DAILY_LIMIT=80
AI_USAGE_RETENTION_DAYS=45

SEED_SAMPLE_DATA=true
BODY_LIMIT=10mb
EXTERNAL_API_TIMEOUT_MS=8000
