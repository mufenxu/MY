# Server
PORT=3045
NODE_ENV=development

# Database
MONGO_URI=mongodb://127.0.0.1:27017/miniprogram
# Optional compatibility variable for some scripts
MONGODB_URI=mongodb://127.0.0.1:27017/miniprogram

# Auth & crypto
CORE_JWT_SECRET=replace_with_a_strong_random_string
# Backward-compatible fallback for standalone deployments:
# JWT_SECRET=replace_with_a_strong_random_string
ENCRYPTION_KEY=replace_with_a_32_char_random_string

# WeChat Mini Program
WX_APP_ID=your_wechat_app_id
WX_APP_SECRET=your_wechat_app_secret

# Optional webhook verification secret
GH_TOKEN=
GH_OWNER=Mufenxu
GH_REPO=ct8-login
GH_REPOSITORY=
GH_WORKFLOW=ssh-login.yml
GH_REF=main
GH_WEBHOOK_SECRET=

# MQTT Smart Dashboard API
MQTT_API_KEY=sk_mqttapi_your_token_here
MQTT_API_BASE_URL=https://mqttapi.pxyb.cn
MQTT_PRIMARY_DEVICE_ID=esp8266_living
MQTT_PRIMARY_RELAY_ID=relay1
MQTT_SECONDARY_DEVICE_ID=esp01s_relay
MQTT_SECONDARY_RELAY_ID=relay1

# Order submit concurrency (range: 1-10, default: 3)
ORDER_SUBMIT_CONCURRENCY=3
