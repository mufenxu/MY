# 服务端口
PORT=22101

# Docker 镜像。服务器纯 Docker/Compose 部署时会直接拉取这个镜像，不需要源码。
HGU_IMAGE=mufenxu/hgu:latest

# 是否启用本系统账号登录保护
# 生产环境或公网部署必须保持为 true
HGU_APP_AUTH_REQUIRED=true

# 首次启动时创建的管理员账号
# 密码和密钥请保持为空，然后运行 npm run env:setup 自动生成
HGU_ADMIN_USERNAME=admin
HGU_ADMIN_PASSWORD=
HGU_APP_SESSION_SECRET=

# 数据加密密钥：用于加密保存学校 Cookie、Token 和课表缓存
# 建议运行 npm run env:setup 自动生成 32 字节随机密钥
# 如果暂时留空，程序会从 HGU_APP_SESSION_SECRET 安全派生一个备用密钥
HGU_DATA_ENCRYPTION_KEY=

# 本系统登录状态有效时间，单位：小时；720 表示登录 30 天后需要重新登录
HGU_APP_SESSION_TTL_HOURS=720

# 是否只允许通过 HTTPS 发送登录 Cookie
# 公网 HTTPS 部署保持 true；仅本地 HTTP 调试时才改为 false
HGU_APP_COOKIE_SECURE=true

# Cookie 跨站策略，通常保持 Lax 即可
HGU_APP_COOKIE_SAMESITE=Lax

# 本系统账号密码最少位数
HGU_APP_PASSWORD_MIN_LENGTH=12

# 会话签名密钥最少位数
HGU_APP_SESSION_SECRET_MIN_LENGTH=32

# 服务监听地址
# 直接在本机运行建议使用 127.0.0.1；Docker 容器内部使用 0.0.0.0
HGU_HOST=127.0.0.1

# 是否信任反向代理传来的真实客户端 IP
# 只有确认所有请求都经过可信 Nginx、Caddy 或 Traefik 时才设为 true
HGU_TRUST_PROXY=false

# 是否启用 HTTPS 强制访问响应头
# 公网 HTTPS 部署保持 true；本地 HTTP 调试可设为 false
HGU_ENABLE_HSTS=true

# Redirect proxied HTTP requests to HTTPS in public deployments.
# This only trusts X-Forwarded-Proto when HGU_TRUST_PROXY=true.
HGU_ENABLE_HTTPS_REDIRECT=true

# 公网 HTTPS 访问地址。可信反向代理把上游 Host 改成 127.0.0.1 时，
# 服务会使用这个地址生成 HTTP -> HTTPS 跳转，避免微信打开 hgu.pxyb.cn 时跳到本机地址。
HGU_PUBLIC_ORIGIN=https://hgu.pxyb.cn

# 可选：学校后续新增的官方 HTTPS 域名，多个域名用英文逗号分隔
# 通常保持为空；只有日志明确显示新的官方域名被拦截，且核验域名归属后才填写
HGU_EXTRA_ALLOWED_SCHOOL_HOSTS=

# 可选：NAS、NFS、CIFS 等不允许修改文件所有者时，填写宿主机 data 目录的数字 UID/GID
# 普通 Linux、Windows、macOS Docker 环境请保持为空，程序会自动检测
HGU_DATA_UID=
HGU_DATA_GID=

# 可选：能耗平台手动 Cookie 备用方案
# 网页已支持学校统一身份认证登录，一般不需要配置下面两项
# 多用户部署不要启用，因为该 Cookie 会被整个服务器共用
HGU_ALLOW_GLOBAL_NRG_COOKIE=false
NRG_COOKIE=

# 可选：从文件读取能耗平台 Cookie，而不是直接写在环境变量中
# NRG_COOKIE_FILE=/run/secrets/hgu_nrg_cookie

# 学校 Cookie 没有返回明确过期时间时，默认按多少小时估算有效期
NRG_SESSION_TTL_HOURS=12

# 能耗仪表实时读数请求超时时间，单位：毫秒；6000 表示 6 秒
NRG_METER_LIVE_TIMEOUT_MS=6000

# 后台自动刷新教务课表的间隔，单位：毫秒
# 600000 表示 10 分钟；设为 0 可关闭后台自动刷新
# 即使关闭，用户打开课表页面时仍会尝试实时同步
ACADEMIC_AUTO_REFRESH_MS=600000
