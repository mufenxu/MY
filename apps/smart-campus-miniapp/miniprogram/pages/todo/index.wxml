<view class="todo-page">
  <!-- 背景装饰 -->
  <view class="bg-decoration bg-decoration--1"></view>
  <view class="bg-decoration bg-decoration--2"></view>

  <view class="content-wrapper">
    <!-- 顶部统计卡片 -->
    <view class="glass-card hero-card">
      <view class="hero-header">
        <view class="hero-title">待办清单</view>
        <view class="hero-date">{{todayDate}}</view>
      </view>
      <view class="hero-stats">
        <view class="stat-item">
          <text class="stat-num">{{activeCount}}</text>
          <text class="stat-label">待处理</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num">{{completedCount}}</text>
          <text class="stat-label">已完成</text>
        </view>
      </view>
      <view class="progress-bar">
        <view class="progress-bar__fill" style="width: {{progressPercent}}%"></view>
      </view>
    </view>

    <!-- 输入区域 -->
    <view class="glass-card input-card">
      <input
        class="todo-input"
        placeholder="添加新的待办事项..."
        placeholder-class="todo-input__placeholder"
        value="{{inputValue}}"
        confirm-type="done"
        bindinput="onInputChange"
        bindconfirm="onAddTask"
        aria-label="待办事项内容"
      />
      <view
        class="add-btn-wrapper"
        bindtap="onAddTask"
        style="opacity: {{canSubmit ? 1 : 0.5}}"
        aria-role="button"
        aria-label="添加待办事项"
        aria-disabled="{{!canSubmit}}"
      >
        <view class="add-icon" aria-hidden="true"></view>
      </view>
    </view>

    <!-- 过滤器 -->
    <view class="filter-bar" aria-role="tablist" aria-label="待办筛选">
      <view
        class="filter-item {{filter==='all'?'filter-item--active':''}}"
        data-filter="all"
        bindtap="onFilterChange"
        aria-role="tab"
        aria-selected="{{filter === 'all'}}"
      >全部</view>
      <view
        class="filter-item {{filter==='active'?'filter-item--active':''}}"
        data-filter="active"
        bindtap="onFilterChange"
        aria-role="tab"
        aria-selected="{{filter === 'active'}}"
      >进行中</view>
      <view
        class="filter-item {{filter==='completed'?'filter-item--active':''}}"
        data-filter="completed"
        bindtap="onFilterChange"
        aria-role="tab"
        aria-selected="{{filter === 'completed'}}"
      >已完成</view>
    </view>

    <!-- 任务列表 -->
    <scroll-view scroll-y class="todo-list" wx:if="{{filteredTasks.length}}" show-scrollbar="{{false}}" enhanced="{{true}}">
      <block wx:for="{{filteredTasks}}" wx:key="id">
        <view class="todo-item {{item.completed?'todo-item--done':''}}">
          <view
            class="todo-toggle"
            bindtap="onToggleTask"
            data-id="{{item.id}}"
            aria-role="checkbox"
            aria-checked="{{item.completed}}"
            aria-label="{{item.completed ? '标记为未完成' : '标记为已完成'}}：{{item.title}}"
          >
            <view class="checkbox {{item.completed?'checkbox--checked':''}}" aria-hidden="true">
              <view class="checkmark" wx:if="{{item.completed}}"></view>
            </view>
            <view class="todo-content">
              <view class="todo-title">{{item.title}}</view>
              <view class="todo-time" wx:if="{{item._createdText}}">{{item._createdText}}</view>
            </view>
          </view>
          <view class="todo-actions">
            <view class="action-btn edit-btn" catchtap="onEditTask" data-id="{{item.id}}" aria-role="button" aria-label="编辑：{{item.title}}">
              <view class="icon-edit" aria-hidden="true"></view>
            </view>
            <view class="action-btn delete-btn" catchtap="onDeleteTask" data-id="{{item.id}}" aria-role="button" aria-label="删除：{{item.title}}">
              <view class="icon-delete" aria-hidden="true"></view>
            </view>
          </view>
        </view>
      </block>
      
      <view class="clear-btn-wrapper" wx:if="{{completedCount > 0 && filter !== 'active'}}">
        <view class="clear-btn" bindtap="onClearCompleted" aria-role="button">清除已完成任务</view>
      </view>
    </scroll-view>

    <!-- 空状态 -->
    <view class="empty-state" wx:else>
      <view class="empty-icon-glass"></view>
      <view class="empty-text">暂无任务，享受当下</view>
    </view>
  </view>

  <!-- 编辑弹窗 -->
  <view class="glass-modal-mask {{showEditor?'visible':''}}" bindtap="onCloseEditor" aria-hidden="{{!showEditor}}">
    <view class="glass-modal {{showEditor?'visible':''}}" catchtap="stopProp" aria-role="dialog" aria-modal="true" aria-label="{{editingTaskId?'编辑任务':'新建任务'}}">
      <view class="modal-header">
        <text>{{editingTaskId?'编辑任务':'新建任务'}}</text>
      </view>
      <textarea
        class="modal-input"
        value="{{editorValue}}"
        placeholder="输入任务内容..."
        placeholder-class="modal-input__placeholder"
        auto-height
        bindinput="onEditorInput"
        aria-label="任务内容"
      />
      <view class="modal-footer">
        <view class="modal-btn cancel-btn" bindtap="onCloseEditor" aria-role="button">取消</view>
        <view class="modal-btn confirm-btn {{!editorCanSubmit?'disabled':''}}" bindtap="onSubmitEditor" aria-role="button" aria-disabled="{{!editorCanSubmit}}">保存</view>
      </view>
    </view>
  </view>
</view>

