
.container {
  min-height: 100vh;
  background: #f0f4f8; /* 拟态大背景 */
  padding: 16px;
  box-sizing: border-box;
}

.news-content {
  width: 100%;
  animation: slideUpFade 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  display: flex;
  flex-direction: column;
}

@keyframes slideUpFade {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

.header-card {
  background: #f0f4f8;
  padding: 24px;
  border-radius: 32px;
  border: 2px solid rgba(255, 255, 255, 0.8);
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
  box-shadow: 
    10px 10px 20px rgba(166, 180, 200, 0.5),
    -10px -10px 20px rgba(255, 255, 255, 0.9),
    inset 2px 2px 4px rgba(255, 255, 255, 0.8),
    inset -2px -2px 4px rgba(166, 180, 200, 0.2);
}

.header-left {
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 20px;
  font-weight: 800;
  color: #1a202c;
  letter-spacing: -0.5px;
}

.date {
  font-size: 13px;
  color: #a0aec0;
  margin-top: 6px;
  font-weight: 500;
}

.weather-icon {
  font-size: 32px;
  background: #f7fafc;
  width: 56px;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16px;
}

.news-list-container {
  padding-bottom: 40px;
}

.news-item {
  background: #f0f4f8;
  margin-bottom: 16px;
  border-radius: 24px;
  padding: 20px;
  display: flex;
  border: 2px solid rgba(255, 255, 255, 0.8);
  box-shadow: 
    8px 8px 16px rgba(166, 180, 200, 0.5),
    -8px -8px 16px rgba(255, 255, 255, 0.9),
    inset 2px 2px 4px rgba(255, 255, 255, 0.8),
    inset -2px -2px 4px rgba(166, 180, 200, 0.2);
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.news-item:active {
  transform: scale(0.97);
  box-shadow: 
    inset 6px 6px 12px rgba(166, 180, 200, 0.5),
    inset -6px -6px 12px rgba(255, 255, 255, 0.9);
}

.item-index {
  font-size: 14px;
  font-weight: 800;
  color: #e2e8f0;
  width: 32px;
  flex-shrink: 0;
  padding-top: 4px;
}

.item-content {
  flex: 1;
}

.item-text {
  font-size: 15px;
  color: #2d3748;
  line-height: 1.6;
  text-align: justify;
  font-weight: 400;
}

.footer-info {
  text-align: center;
  padding: 20px 0 40px;
}

.footer-text {
  font-size: 12px;
  color: #cbd5e0;
  letter-spacing: 1px;
}


/* 搞怪模式特殊样式 */
.is-playful {
  background: linear-gradient(135deg, #fff5f5 0%, #fffaf0 100%) !important;
  overflow: hidden;
  position: relative;
}

/* 背景搞怪漂浮物 */
.bg-bubble {
  position: absolute;
  font-size: 24px;
  opacity: 0.1;
  z-index: 0;
  pointer-events: none;
  animation: floatAround 10s infinite linear;
}

@keyframes floatAround {
  0% { transform: translate3d(0, 0, 0) rotate(0deg); }
  25% { transform: translate3d(100px, 100px, 0) rotate(90deg); }
  50% { transform: translate3d(200px, 0, 0) rotate(180deg); }
  75% { transform: translate3d(100px, -100px, 0) rotate(270deg); }
  100% { transform: translate3d(0, 0, 0) rotate(360deg); }
}

.maintenance-tag {
  background: linear-gradient(90deg, #ff9a9e 0%, #fad0c4 100%);
  color: #fff;
  font-size: 11px;
  font-weight: 800;
  padding: 6px 16px;
  border-radius: 100px;
  display: inline-block;
  margin-bottom: 24px;
  text-transform: uppercase;
  letter-spacing: 2px;
  box-shadow: 0 4px 12px rgba(255, 154, 158, 0.3);
  animation: pulse 2s infinite;
  z-index: 1;
}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.05); }
  100% { transform: scale(1); }
}

.weather-icon.spinning {
  animation: crazySpin 3s infinite ease-in-out;
  display: inline-flex;  /* 使用 flex 保证 text 居中 */
  align-items: center;
  justify-content: center;
  font-family: "Apple Color Emoji", "Segoe UI Emoji", "Noto Color Emoji", sans-serif; /* 强制兜底表情字体 */
}

@keyframes crazySpin {
  0% { transform: translate3d(0,0,0) rotate(0deg) scale(1); }
  25% { transform: translate3d(0,0,0) rotate(15deg) scale(1.2); }
  50% { transform: translate3d(0,0,0) rotate(-15deg) scale(0.9); }
  75% { transform: translate3d(0,0,0) rotate(10deg) scale(1.1); }
  100% { transform: translate3d(0,0,0) rotate(0deg) scale(1); }
}

.humor-tip {
  margin-top: 40px;
  padding: 24px;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 20px;
  border: 4px dashed #fad0c4;
  position: relative;
  z-index: 1;
  transform: rotate(-1deg);
}

.humor-tip::before {
  content: 'NOTICE';
  position: absolute;
  top: -12px;
  left: 20px;
  background: #fad0c4;
  color: #fff;
  font-size: 10px;
  font-weight: bold;
  padding: 2px 10px;
  border-radius: 4px;
}

.tip-content {
  font-size: 14px;
  color: #8b6d6d;
  line-height: 1.8;
  font-style: italic;
  font-weight: 500;
}

.news-item {
  position: relative;
  z-index: 1;
  background: rgba(255, 255, 255, 0.3);
  margin-bottom: 12px;
  border-radius: 16px;
  padding: 16px;
  border: 1px solid rgba(255, 255, 255, 0.5);
}
