page {
  background-color: #f0f4f8;
}

/* 页面容器 - Apple 风格浅灰背景 */
.page-container {
  background-color: #f0f4f8;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  color: #1d1d1f;
}

/* 顶部 Tab - 极简风格 */
.tabs-header {
  display: flex;
  background-color: rgba(240, 244, 248, 0.85); /* 统一为页面背景色 #f0f4f8 */
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  padding: 0 16rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
  color: #86868b;
  position: relative;
  transition: all 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  font-weight: 500;
}

.tab-item.active {
  color: #1d1d1f;
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #0071e3;
  border-radius: 4rpx;
}

/* 内容区域 */
.content-area {
  padding: 32rpx;
  padding-bottom: 32rpx;
}

/* 通用卡片样式 - 悬浮感 */
.card {
  background-color: #f0f4f8;
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 
    12px 12px 24px rgba(166, 180, 200, 0.5),
    -12px -12px 24px rgba(255, 255, 255, 0.9),
    inset 2px 2px 4px rgba(255, 255, 255, 0.8),
    inset -2px -2px 4px rgba(166, 180, 200, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.card:active {
  transform: scale(0.99);
  box-shadow: 
    inset 6px 6px 12px rgba(166, 180, 200, 0.5),
    inset -6px -6px 12px rgba(255, 255, 255, 0.9);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1d1d1f;
  letter-spacing: -0.5rpx;
}

/* 状态徽章 */
.status-badge {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.status-success { background-color: rgba(52, 199, 89, 0.1); color: #34c759; }
.status-failed { background-color: rgba(255, 59, 48, 0.1); color: #ff3b30; }
.status-partial { background-color: rgba(255, 149, 0, 0.1); color: #ff9500; }
.status-running { background-color: rgba(0, 113, 227, 0.1); color: #0071e3; }

/* 任务执行中提示条 */
.running-banner {
  margin: 4rpx 0 32rpx;
  animation: slideDown 0.4s cubic-bezier(0.32, 0.72, 0, 1);
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.running-banner-inner {
  display: flex;
  align-items: center;
  min-height: 172rpx;
  padding: 30rpx 30rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(240, 250, 255, 0.98) 48%, rgba(229, 255, 248, 0.96) 100%);
  border: 1rpx solid rgba(181, 225, 230, 0.72);
  border-radius: 30rpx;
  box-shadow: 0 16rpx 38rpx rgba(84, 157, 184, 0.16), inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  position: relative;
  overflow: hidden;
}

.running-banner-inner::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(135deg, rgba(14, 165, 233, 0.08) 0%, transparent 38%),
    linear-gradient(315deg, rgba(45, 212, 191, 0.1) 0%, transparent 36%);
  opacity: 0.9;
}

.running-banner-inner::after {
  content: '';
  position: absolute;
  left: 118rpx;
  right: 42rpx;
  bottom: 30rpx;
  height: 2rpx;
  background: linear-gradient(90deg, rgba(14, 165, 233, 0), rgba(14, 165, 233, 0.32), rgba(45, 212, 191, 0.54), rgba(255, 255, 255, 0));
  animation: runningSweep 2.6s ease-in-out infinite;
}

@keyframes runningSweep {
  0% { transform: translateX(-60%); opacity: 0; }
  24% { opacity: 0.88; }
  100% { transform: translateX(48%); opacity: 0; }
}

.running-mark {
  width: 82rpx;
  height: 82rpx;
  margin-right: 26rpx;
  flex-shrink: 0;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.running-mark-orbit {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 2rpx solid rgba(14, 165, 233, 0.18);
  border-top-color: rgba(14, 165, 233, 0.78);
  border-right-color: rgba(45, 212, 191, 0.72);
  box-shadow: 0 0 24rpx rgba(14, 165, 233, 0.1);
  animation: orbitSpin 2.2s linear infinite;
}

.running-mark-core {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.76);
  color: #0f766e;
  font-size: 19rpx;
  font-weight: 800;
  line-height: 52rpx;
  text-align: center;
  border: 1rpx solid rgba(14, 165, 233, 0.16);
  box-shadow: 0 8rpx 20rpx rgba(14, 165, 233, 0.12), inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  letter-spacing: 0;
}

.running-mark-dot {
  position: absolute;
  right: 4rpx;
  top: 10rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #34c759;
  box-shadow: 0 0 0 8rpx rgba(52, 199, 89, 0.12), 0 0 16rpx rgba(52, 199, 89, 0.38);
  animation: liveDot 1.5s ease-in-out infinite;
}

@keyframes orbitSpin {
  to { transform: rotate(360deg); }
}

@keyframes liveDot {
  0%, 100% { opacity: 0.72; transform: scale(0.9); }
  50% { opacity: 1; transform: scale(1); }
}

.running-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 1;
}

.running-head {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
  min-width: 0;
}

.running-kicker {
  color: #0f8aa5;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1.25;
  margin-right: 12rpx;
  font-family: 'SF Mono', SFMono-Regular, ui-monospace, monospace;
}

.running-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1d1d1f;
  letter-spacing: 0;
  line-height: 1.25;
}

.running-chip {
  flex-shrink: 0;
  padding: 5rpx 13rpx;
  border-radius: 999rpx;
  background: rgba(52, 199, 89, 0.1);
  color: #1f9d55;
  font-size: 19rpx;
  font-weight: 700;
  line-height: 1.3;
  border: 1rpx solid rgba(52, 199, 89, 0.14);
}

.running-meta {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 10rpx;
  color: #6e7b86;
  font-size: 23rpx;
  font-family: 'SF Mono', SFMono-Regular, ui-monospace, monospace;
  line-height: 1.3;
}

.running-pipeline {
  display: flex;
  align-items: center;
  width: 100%;
  max-width: 360rpx;
  margin-top: 22rpx;
}

.pipeline-node {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(188, 206, 214, 0.72);
  box-shadow: 0 0 0 6rpx rgba(188, 206, 214, 0.12);
  flex-shrink: 0;
}

.pipeline-node.active {
  background: #35c7c2;
  box-shadow: 0 0 0 7rpx rgba(53, 199, 194, 0.12), 0 0 16rpx rgba(53, 199, 194, 0.26);
}

.pipeline-line {
  flex: 1;
  height: 4rpx;
  margin: 0 8rpx;
  border-radius: 999rpx;
  background: rgba(174, 199, 207, 0.36);
  overflow: hidden;
  position: relative;
}

.pipeline-line.active {
  background: rgba(53, 199, 194, 0.42);
}

.pipeline-line.flow::before {
  content: '';
  position: absolute;
  top: 0;
  bottom: 0;
  width: 58rpx;
  border-radius: inherit;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.96), transparent);
  animation: pipeFlow 1.8s ease-in-out infinite;
}

@keyframes pipeFlow {
  from { transform: translateX(-62rpx); opacity: 0; }
  25% { opacity: 1; }
  to { transform: translateX(156rpx); opacity: 0; }
}

.running-terminal {
  width: 112rpx;
  height: 92rpx;
  padding: 16rpx 14rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.66);
  border: 1rpx solid rgba(181, 225, 230, 0.48);
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
  margin-left: 22rpx;
  position: relative;
  z-index: 1;
  box-shadow: 0 8rpx 20rpx rgba(84, 157, 184, 0.1), inset 0 1rpx 0 rgba(255, 255, 255, 0.82);
}

.terminal-line {
  height: 6rpx;
  border-radius: 999rpx;
  background: rgba(38, 160, 184, 0.34);
}

.terminal-line.wide { width: 72rpx; }
.terminal-line.mid { width: 54rpx; }
.terminal-line.short { width: 36rpx; }

.terminal-cursor {
  width: 16rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #35c7c2;
  animation: terminalBlink 1s steps(2, start) infinite;
}

@keyframes terminalBlink {
  50% { opacity: 0.24; }
}

/* 运行状态网格 */
.status-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.grid-item {
  display: flex;
  flex-direction: column;
  background-color: #F5F5F7;
  padding: 24rpx;
  border-radius: 20rpx;
}

.grid-item .label {
  font-size: 24rpx;
  color: #86868b;
  margin-bottom: 8rpx;
}

.grid-item .value {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d1d1f;
  font-family: 'SF Mono', SFMono-Regular, ui-monospace, monospace;
}

.value.success-text { color: #34c759; }
.value.failed-text { color: #ff3b30; }

.callback-alert {
  margin: -16rpx 0 32rpx;
  padding: 18rpx 22rpx;
  border-radius: 18rpx;
  background-color: rgba(255, 149, 0, 0.12);
  color: #b45309;
  font-size: 24rpx;
  line-height: 1.4;
}

/* 时间信息 */
.time-info {
  background-color: #F5F5F7;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
}

.time-row {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  margin-bottom: 12rpx;
}

.time-row:last-child {
  margin-bottom: 0;
}

.time-row .label {
  color: #86868b;
}

.time-row .value {
  color: #1d1d1f;
  font-weight: 500;
  font-family: 'SF Mono', SFMono-Regular, ui-monospace, monospace;
}

.time-row .duration-value {
  color: #0071e3;
  font-weight: 600;
}

/* 按钮样式 */
.btn {
  border-radius: 100rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  border: none;
}

.btn::after {
  border: none;
}

.primary-btn {
  background-color: #0071e3;
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 113, 227, 0.3);
}

.primary-btn:active {
  background-color: #0077ED;
  transform: scale(0.98);
}

.primary-btn[disabled] {
  background-color: #a1a1a6;
  box-shadow: none;
  color: rgba(255, 255, 255, 0.8);
}

.outline-btn {
  background-color: transparent;
  color: #0071e3;
  border: 2rpx solid rgba(0, 113, 227, 0.3);
}

.outline-btn:active {
  background-color: rgba(0, 113, 227, 0.05);
}

.action-buttons {
  display: flex;
  gap: 24rpx;
}

.action-buttons .btn {
  flex: 1;
}

/* 历史记录 */
.history-list {
  display: flex;
  flex-direction: column;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.history-item:last-child {
  border-bottom: none;
}

.history-item:active {
  opacity: 0.6;
}

.history-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  flex-shrink: 0;
  align-self: flex-start;
  margin-top: 12rpx;
}

.history-dot.status-success { background-color: #34c759; }
.history-dot.status-failed { background-color: #ff3b30; }
.history-dot.status-partial { background-color: #ff9500; }
.history-dot.status-running { background-color: #0071e3; }

.history-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.history-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.history-time {
  font-size: 30rpx;
  color: #1d1d1f;
  font-weight: 500;
  flex-shrink: 0;
}

.history-nums {
  font-size: 26rpx;
  color: #86868b;
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.history-nums.callback-pending {
  color: #b45309;
  font-weight: 500;
}

.history-duration {
  display: flex;
  align-items: center;
  margin-top: 6rpx;
}

.duration-icon {
  font-size: 22rpx;
  margin-right: 6rpx;
  color: #86868b;
}

.duration-text {
  font-size: 22rpx;
  color: #0071e3;
  font-weight: 500;
  font-family: 'SF Mono', SFMono-Regular, ui-monospace, monospace;
}

.num-success {
  color: #86868b;
}

.num-sep {
  margin: 0 10rpx;
  color: #d2d2d7;
}

.num-failed {
  color: #86868b;
}

.num-failed.has-failed {
  color: #ff3b30;
  font-weight: 500;
}

.num-success:active,
.num-failed:active {
  opacity: 0.5;
}

.history-arrow {
  color: #c7c7cc;
  font-size: 32rpx;
  margin-left: 16rpx;
  font-weight: 300;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #86868b;
  margin-bottom: 48rpx;
}

.btn.small {
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  width: auto;
}

/* 重构：模式选择网格 */
.mode-selection-grid {
  display: flex;
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.mode-card {
  flex: 1;
  background-color: #ffffff;
  border-radius: 28rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  position: relative;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 4rpx solid transparent;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
}

.mode-card.active {
  border-color: #0071e3;
  background-color: rgba(0, 113, 227, 0.02);
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 24rpx rgba(0, 113, 227, 0.1);
}

.mode-card:active {
  transform: scale(0.96);
}

.mode-card-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: #F5F5F7;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 20rpx;
  transition: all 0.3s ease;
}

.mode-card.active .mode-card-icon {
  background-color: #0071e3;
  color: #ffffff;
  transform: rotate(360deg);
}

.mode-card-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.mode-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1d1d1f;
}

.mode-card-desc {
  font-size: 22rpx;
  color: #86868b;
  line-height: 1.2;
}

.mode-card-dot {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 12rpx;
  height: 12rpx;
  background-color: #0071e3;
  border-radius: 50%;
  box-shadow: 0 0 12rpx rgba(0, 113, 227, 0.4);
}

/* 输入框区域 */
.input-card .badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.input-card .badge.success { background-color: rgba(52, 199, 89, 0.1); color: #34c759; }
.input-card .badge.warning { background-color: rgba(255, 149, 0, 0.1); color: #ff9500; }

.input-wrapper {
  background-color: #f0f4f8;
  border-radius: 20rpx;
  padding: 24rpx;
  min-height: 120rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 
    inset 6rpx 6rpx 12rpx rgba(166, 180, 200, 0.4),
    inset -6rpx -6rpx 12rpx rgba(255, 255, 255, 0.9);
}

.textarea {
  width: 100%;
  font-size: 28rpx;
  line-height: 1.5;
  color: #1d1d1f;
  min-height: 120rpx;
}

.textarea.big {
  min-height: 200rpx;
}

.mono {
  font-family: 'SF Mono', SFMono-Regular, ui-monospace, monospace;
}

.char-count {
  font-size: 24rpx;
  color: #86868b;
}

.current-value-display {
  background-color: #f0f4f8;
  border-radius: 20rpx;
  padding: 24rpx;
  word-break: break-all;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 
    inset 6rpx 6rpx 12rpx rgba(166, 180, 200, 0.4),
    inset -6rpx -6rpx 12rpx rgba(255, 255, 255, 0.9);
}

.update-time {
  font-size: 22rpx;
  color: #86868b;
  margin-top: 16rpx;
  text-align: right;
}

/* Secret 标签列表 */
.secret-tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 4rpx 0;
}

.secret-tag {
  display: inline-flex;
  align-items: center;
  background-color: #F5F5F7;
  border-radius: 100rpx;
  padding: 12rpx 12rpx 12rpx 24rpx;
  font-size: 26rpx;
  color: #1d1d1f;
  transition: all 0.2s ease;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.secret-tag:active {
  background-color: #EBEBED;
}

.tag-text {
  font-family: 'SF Mono', SFMono-Regular, ui-monospace, monospace;
  font-weight: 500;
  margin-right: 8rpx;
  line-height: 1.2;
}

.tag-delete {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #86868b;
  flex-shrink: 0;
  transition: all 0.15s ease;
}

.tag-delete:active {
  background-color: rgba(255, 59, 48, 0.15);
  color: #ff3b30;
}

/* 预览区域 */
.preview-box {
  background-color: #f8f9fa;
  color: #1d1d1f;
  padding: 32rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  line-height: 1.6;
  word-break: break-all;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  position: relative;
}

.preview-box::after {
  content: '预览最终结果';
  position: absolute;
  bottom: 0;
  right: 24rpx;
  font-size: 20rpx;
  color: rgba(0, 0, 0, 0.2);
  font-weight: 600;
}

.preview-box .muted {
  color: #a1a1a6;
}

.preview-box .highlight {
  color: #34c759;
  font-weight: 700;
  text-decoration: underline;
  text-underline-offset: 4rpx;
}

.footer-actions {
  margin-top: 40rpx;
}

.btn.block {
  width: 100%;
}

/* 可点击提示 */
.clickable {
  position: relative;
}

.tap-hint {
  font-size: 20rpx;
  color: #86868b;
  margin-top: 4rpx;
  display: block;
}

.grid-item[bindtap]:active {
  background-color: #EBEBED;
  transform: scale(0.97);
}

/* 弹窗遮罩层 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0);
  z-index: 1000;
  pointer-events: none;
  visibility: hidden;
  transition: background-color 0.35s ease, visibility 0s linear 0.4s;
}

.modal-overlay.show {
  background-color: rgba(0, 0, 0, 0.4);
  pointer-events: auto;
  visibility: visible;
  transition: background-color 0.35s ease, visibility 0s linear 0s;
}

/* 弹窗面板 - 底部半屏 */
.modal-sheet {
  position: relative;
  width: 100%;
  background-color: #F5F5F7;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 75vh;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1);
  display: flex;
  flex-direction: column;
  z-index: 1001;
}

.modal-sheet.show {
  transform: translateY(0);
}

.modal-handle {
  width: 64rpx;
  height: 8rpx;
  background-color: #d2d2d7;
  border-radius: 4rpx;
  margin: 16rpx auto 0;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 40rpx 20rpx;
  flex-shrink: 0;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1d1d1f;
  letter-spacing: -0.5rpx;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: rgba(118, 118, 128, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #86868b;
  font-weight: 600;
}

.modal-close:active {
  background-color: rgba(118, 118, 128, 0.2);
}

.modal-body {
  overflow-y: auto;
  padding: 0 32rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  flex: 1;
}

.modal-empty {
  text-align: center;
  padding: 80rpx 0;
  color: #86868b;
  font-size: 30rpx;
}

/* 弹窗中的服务器卡片 */
.server-item {
  background-color: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.server-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.server-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  word-break: break-all;
}

.server-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  font-weight: 600;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.server-status.status-ok {
  background-color: rgba(52, 199, 89, 0.1);
  color: #34c759;
}

.server-status.status-err {
  background-color: rgba(255, 59, 48, 0.1);
  color: #ff3b30;
}

.server-item-body {
  padding: 20rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.server-detail-row {
  display: flex;
  align-items: center;
  font-size: 26rpx;
}

.detail-label {
  color: #86868b;
  width: 140rpx;
  flex-shrink: 0;
}

.detail-value {
  color: #1d1d1f;
  font-family: 'SF Mono', SFMono-Regular, ui-monospace, monospace;
  word-break: break-all;
  flex: 1;
}

/* 可点击的文字强调 */
.clickable-text {
  text-decoration: underline;
  text-decoration-style: dotted;
  text-underline-offset: 4rpx;
}

.history-summary .success:active,
.history-summary .failed:active {
  opacity: 0.6;
}

/* 列表底部占位与操作区 */
.list-footer {
  padding: 24rpx 0;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
}

.list-footer.with-action {
  padding-top: 40rpx;
}

.list-footer.hint-only {
  padding-top: 16rpx;
}

.list-bottom-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 0;
  width: 100%;
}

.list-footer.with-action .list-bottom-hint {
  margin-bottom: 32rpx;
}

.list-bottom-hint .line {
  height: 1rpx;
  width: 80rpx;
  background-color: rgba(0, 0, 0, 0.08);
}

.list-bottom-hint .hint-text {
  font-size: 24rpx;
  color: #a1a1a6;
  margin: 0 24rpx;
  letter-spacing: 2rpx;
}

.block-btn {
  width: 85%;
  margin: 0 auto;
  padding: 26rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(0, 113, 227, 0.25);
}
