.page {
  padding: 16px;
  background: #f0f4f8;
  min-height: 100vh;
}

.section {
  margin-bottom: 20px;
}

.title {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 16px;
  color: #2c3e50;
  padding-left: 4px;
}

.server-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.server-card {
  background: #f0f4f8;
  border-radius: 24px;
  border: 2px solid rgba(255, 255, 255, 0.8);
  box-shadow: 
    10px 10px 20px rgba(166, 180, 200, 0.5),
    -10px -10px 20px rgba(255, 255, 255, 0.9),
    inset 2px 2px 4px rgba(255, 255, 255, 0.8),
    inset -2px -2px 4px rgba(166, 180, 200, 0.2);
  overflow: hidden;
  transition: all 0.3s ease;
}

.card-header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 16px;
  background: transparent;
  border-bottom: 2px solid rgba(255,255,255,0.4);
  position: relative;
}

.account-info {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
}

.account-icon {
  font-size: 24px;
  margin-right: 12px;
  line-height: 1;
}

.account-name {
  font-size: 18px;
  font-weight: 600;
  color: #2c3e50;
  word-break: break-all;
}

.status-badge {
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 12px;
  font-weight: 500;
  white-space: nowrap;
  position: absolute;
  right: 16px;
}

.status-success {
  background: #d4edda;
  color: #155724;
}

.status-error {
  background: #f8d7da;
  color: #721c24;
}

.status-default {
  background: #d1ecf1;
  color: #0c5460;
}

.card-body {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 12px;
  background: #f8f9fa;
  border-radius: 8px;
}

.info-icon {
  font-size: 20px;
  margin-right: 12px;
  line-height: 1;
  margin-top: 2px;
}

.info-content {
  flex: 1;
}

.info-label {
  font-size: 13px;
  color: #6c757d;
  margin-bottom: 4px;
}

.info-value {
  font-size: 15px;
  color: #2c3e50;
  font-weight: 500;
  font-family: 'SF Mono', 'Monaco', 'Courier New', monospace;
}

.copy-btn {
  margin-top: 6px;
}

.back-btn {
  margin-top: 16px;
}
