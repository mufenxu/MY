/* 现代简约，带有拟态厚重感设计理念 */
page {
  background-color: #f0f4f8;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  color: #1A1A1A;
  --primary: #2563EB; /* 稳重的科技蓝 */
  --primary-light: #EFF6FF; /* 极浅蓝背景，更通透 */
  --text-main: #1A1A1A;
  --text-sub: #666666;
  --text-muted: #999999;
  --bg-input: rgba(240, 244, 248, 0.8);
  --border-light: #EBEDF0;
}

.page {
  padding: 40rpx 32rpx 60rpx;
  box-sizing: border-box;
}

/* Card Common */
.card {
  background: #f0f4f8;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 40rpx;
  padding: 40rpx 32rpx;
  box-shadow: 
    20rpx 20rpx 40rpx rgba(166, 180, 200, 0.5),
    -20rpx -20rpx 40rpx rgba(255, 255, 255, 0.9),
    inset 4rpx 4rpx 8rpx rgba(255, 255, 255, 0.8),
    inset -4rpx -4rpx 8rpx rgba(166, 180, 200, 0.2);
  margin-bottom: 40rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 48rpx;
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-main);
  position: relative;
  padding-left: 24rpx;
}

.card-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 28rpx;
  background-color: var(--primary);
  border-radius: 4rpx;
}

.card-action {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--primary);
  background: var(--primary-light);
  display: flex;
  align-items: center;
  padding: 10rpx 24rpx;
  border-radius: 100rpx;
  transition: all 0.2s;
}

.card-action:active {
  opacity: 0.8;
  transform: scale(0.96);
}

.icon-arrow {
  width: 10rpx;
  height: 10rpx;
  border-top: 4rpx solid var(--primary);
  border-right: 4rpx solid var(--primary);
  transform: rotate(45deg);
  margin-left: 8rpx;
  margin-top: 2rpx;
  border-radius: 2rpx;
}

/* Form */
.form-group {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  margin-bottom: 48rpx;
}

.form-row {
  display: flex;
  gap: 24rpx;
}

.flex-1 {
  flex: 1;
  min-width: 0;
}

.form-label {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-main);
  margin-bottom: 16rpx;
}

.optional {
  color: var(--text-muted);
  font-weight: normal;
  font-size: 24rpx;
}

.input, .picker-view {
  background: #f0f4f8;
  border-radius: 24rpx;
  height: 96rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  color: var(--text-main);
  box-sizing: border-box;
  transition: all 0.3s;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 
    inset 6rpx 6rpx 12rpx rgba(166, 180, 200, 0.4),
    inset -6rpx -6rpx 12rpx rgba(255, 255, 255, 0.9);
}

.picker-view {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: var(--text-muted);
}

.picker-view.has-val {
  color: var(--text-main);
}

.dropdown-icon {
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 10rpx solid var(--text-muted);
}

.ph-color {
  color: var(--text-muted);
}

.platform-notice {
  background: var(--primary-light);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-top: -16rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.notice-icon {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: bold;
  background: #FFFFFF;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.notice-text {
  font-size: 26rpx;
  color: var(--text-sub);
  line-height: 1.6;
  white-space: pre-wrap;
}

.input:focus {
  background: #FFFFFF;
  border-color: var(--primary);
  box-shadow: 0 0 0 4rpx rgba(37, 99, 235, 0.1);
}

/* Buttons */
.btn-primary {
  background: var(--primary);
  color: #FFFFFF;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  transition: opacity 0.2s;
}

.btn-primary[disabled] {
  background: #93C5FD !important; /* disabled primary - light blue */
  color: #FFFFFF !important;
}

.btn-primary:active {
  opacity: 0.85;
}

/* Result Section */
.result-section {
  opacity: 0;
  transform: translateY(20rpx);
  transition: all 0.4s ease-out;
}

.result-section.show {
  opacity: 1;
  transform: translateY(0);
}

.result-toolbar {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
}

.highlight {
  color: var(--primary);
  margin-left: 8rpx;
  font-size: 34rpx;
}

.select-all-btn {
  font-size: 26rpx;
  color: var(--primary);
  padding: 8rpx 0;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-img {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.8;
}

.empty-folder__tab {
  position: absolute;
  left: 22rpx;
  top: 24rpx;
  width: 46rpx;
  height: 22rpx;
  border-radius: 12rpx 12rpx 0 0;
  background: #dbe4f0;
}

.empty-folder__body {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  top: 42rpx;
  bottom: 24rpx;
  border: 4rpx solid #d1d5db;
  border-radius: 18rpx;
  background: #f6f8fb;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-muted);
}

/* Course List */
.course-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hidden-checkbox {
  display: none;
}

.course-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.02);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.course-item.is-checked {
  border-color: var(--primary);
  background: var(--primary-light);
}

.course-content {
  flex: 1;
  min-width: 0;
  padding-right: 20rpx;
}

.course-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.course-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
}

.course-id {
  font-size: 22rpx;
  color: var(--text-muted);
  font-family: SF Pro Text, Consolas, Monaco, monospace;
}

.course-status-list {
  display: flex;
  gap: 10rpx;
}

.status-tag {
  font-size: 20rpx;
  color: var(--text-sub);
  background: var(--bg-input);
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}

.status-tag.active {
  color: #059669; /* Emerald 600 */
  background: #D1FAE5; /* Emerald 100 */
}

/* 自定义 Checkbox */
.custom-checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #D1D5DB;
  position: relative;
  transition: all 0.2s;
  flex-shrink: 0;
  box-sizing: border-box;
}

.custom-checkbox.checked {
  background-color: var(--primary);
  border-color: var(--primary);
}

.custom-checkbox.checked::after {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 10rpx;
  width: 8rpx;
  height: 14rpx;
  border-right: 3rpx solid #FFFFFF;
  border-bottom: 3rpx solid #FFFFFF;
  transform: rotate(45deg);
}

/* Submit Panel (置于列表上方) */
.submit-panel {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(37, 99, 235, 0.08);
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 4rpx solid var(--primary-light);
  min-height: 140rpx;
  box-sizing: border-box;
}

.submit-info {
  flex: 1;
  min-width: 0;
  padding-right: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.submit-count {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-sub);
  margin-bottom: 12rpx;
}

.submit-count .num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
  margin: 0 8rpx;
}

.selected-names {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.selected-name-item {
  font-size: 22rpx;
  color: var(--primary);
  background: var(--primary-light);
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
  max-width: 100%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  box-sizing: border-box;
}

.no-selection {
  font-size: 24rpx;
  color: var(--text-muted);
}

.btn-submit {
  background: var(--primary);
  color: #FFFFFF;
  margin: 0 !important;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  flex-shrink: 0;
  box-shadow: 0 8rpx 20rpx rgba(37, 99, 235, 0.2);
}

.btn-submit[disabled] {
  background: var(--bg-input) !important;
  color: var(--text-muted) !important;
  box-shadow: none;
}

/* 自定义底部弹窗 */
.custom-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  visibility: hidden;
  transition: visibility 0.4s;
}

.custom-popup.show {
  visibility: visible;
}

.popup-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  opacity: 0;
  transition: opacity 0.4s;
}

.custom-popup.show .popup-mask {
  opacity: 1;
}

.popup-container {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #F7F8FA;
  border-radius: 40rpx 40rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  box-shadow: 0 -4rpx 32rpx rgba(0,0,0,0.1);
  z-index: 2;
  overflow: hidden;
}

.custom-popup.show .popup-container.slide-up {
  transform: translateY(0);
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  border-radius: 40rpx 40rpx 0 0;
  position: relative;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-main);
}

.popup-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F2F3F5;
  border-radius: 50%;
  transition: all 0.2s;
}

.popup-close:active {
  transform: scale(0.9);
  background: #E5E7EB;
}

.close-icon {
  position: relative;
  width: 32rpx;
  height: 32rpx;
}

.close-icon::before,
.close-icon::after {
  content: "";
  position: absolute;
  left: 15rpx;
  top: 2rpx;
  width: 3rpx;
  height: 28rpx;
  border-radius: 2rpx;
  background: #1a1a1a;
}

.close-icon::before {
  transform: rotate(45deg);
}

.close-icon::after {
  transform: rotate(-45deg);
}

.popup-scroll {
  max-height: 60vh;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 16rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.platform-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.platform-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  border: 4rpx solid transparent; 
  transition: all 0.2s;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.02);
}

.platform-item:active {
  transform: scale(0.98);
}

.platform-item.active {
  border-color: var(--primary);
  background: var(--primary-light);
}

.platform-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.platform-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
}

.platform-badges {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap; /* 处理多个标签换行 */
}

.badge-price {
  font-size: 24rpx;
  color: #D97706; /* 修改颜色更沉稳的橙 */
  background: #FEF3C7;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 600;
  line-height: 1.4;
}

.badge-tag {
  font-size: 24rpx;
  color: var(--primary);
  background: #DBEAFE;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 600;
  line-height: 1.4;
}

.platform-radio {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 4rpx solid #D1D5DB;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.platform-item.active .platform-radio {
  border-color: var(--primary);
}

.radio-inner {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: var(--primary);
  transform: scale(0);
  transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1); /* 增加弹性效果 */
}

.platform-item.active .radio-inner {
  transform: scale(1);
}

/* 自定义确认提交弹窗 */
.confirm-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10000;
  visibility: hidden;
}

.confirm-modal.show {
  visibility: visible;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(8px);
  opacity: 0;
  transition: opacity 0.3s;
  z-index: 10000;
}

.confirm-modal.show .modal-mask {
  opacity: 1;
}

.modal-container {
  position: fixed;
  top: 50%;
  left: 50%;
  width: calc(100% - 96rpx); /* 两边保留 48rpx margin */
  max-width: 600rpx;
  background: #f0f4f8;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 40rpx;
  padding: 40rpx 36rpx;
  box-shadow: 
    20rpx 20rpx 40rpx rgba(166, 180, 200, 0.4),
    -20rpx -20rpx 40rpx rgba(255, 255, 255, 0.9);
  z-index: 10001;
  box-sizing: border-box;
  transform: translate(-50%, -50%) scale(0.9);
  opacity: 0;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.confirm-modal.show .modal-container.scale-up {
  transform: translate(-50%, -50%) scale(1);
  opacity: 1;
}

.modal-header {
  margin-bottom: 32rpx;
  text-align: center;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-main);
}

.modal-body {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  box-shadow: inset 2rpx 2rpx 6rpx rgba(0, 0, 0, 0.02);
}

.info-row.align-start {
  align-items: flex-start;
  flex-direction: column;
  gap: 16rpx;
}

.info-label {
  font-size: 26rpx;
  color: var(--text-muted);
  font-weight: 500;
}

.info-value {
  font-size: 28rpx;
  color: var(--text-main);
  font-weight: 600;
}

.course-names-scroll {
  width: 100%;
  max-height: 240rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.modal-course-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  width: 100%;
}

.modal-course-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  width: 100%;
}

.modal-course-bullet {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--primary);
  flex-shrink: 0;
}

.modal-course-name {
  font-size: 28rpx;
  color: var(--text-main);
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
}

.submit-warning {
  font-size: 24rpx;
  color: #D97706; /* 警告黄色 */
  background: #FEF3C7;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  line-height: 1.5;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
}

.btn-cancel, .btn-confirm-submit {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  margin: 0 !important;
}

.btn-cancel {
  background: #FFFFFF;
  color: var(--text-sub);
  border: 2rpx solid var(--border-light);
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.05);
}

.btn-confirm-submit {
  background: var(--primary);
  color: #FFFFFF;
  box-shadow: 0 8rpx 20rpx rgba(37, 99, 235, 0.2);
}

.btn-confirm-submit[disabled] {
  background: #93C5FD !important;
  color: #FFFFFF !important;
}
