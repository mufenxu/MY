<view class="page-container">
  <view class="custom-nav" style="height: {{navBarHeight}}px; padding-top: {{menuButtonTop}}px;">
    <view class="nav-content" style="height: {{menuButtonHeight}}px; line-height: {{menuButtonHeight}}px;">
      <text class="nav-title">个人中心</text>
    </view>
  </view>

  <view class="header-banner"></view>

  <view class="content-wrapper">
    <view class="user-info-card">
      <view class="card-inner">
        <view class="pet-lane" wx:if="{{isLogin}}">
          <view class="study-pet">
            <view class="pet-shadow"></view>
            <view class="pet-tail"></view>
            <view class="pet-body">
              <view class="pet-ear pet-ear-left"></view>
              <view class="pet-ear pet-ear-right"></view>
              <view class="pet-cap">
                <view class="pet-cap-top"></view>
                <view class="pet-cap-tail"></view>
              </view>
              <view class="pet-face">
                <view class="pet-eye pet-eye-left"></view>
                <view class="pet-eye pet-eye-right"></view>
                <view class="pet-nose"></view>
                <view class="pet-cheek pet-cheek-left"></view>
                <view class="pet-cheek pet-cheek-right"></view>
              </view>
              <view class="pet-book">
                <view class="pet-book-line"></view>
              </view>
            </view>
          </view>
        </view>
        <block wx:if="{{isLogin}}">
          <view class="avatar-box">
            <image class="avatar-img" src="{{userInfo.avatarUrl || defaultAvatar}}" mode="aspectFill"></image>
            <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar"></button>
          </view>
          <view class="user-details">
            <input
              type="nickname"
              class="nickname-display"
              placeholder="{{userInfo.nickname || '设置昵称'}}"
              bindinput="onNicknameInput"
              bindblur="onNicknameBlur"
            />
            <text class="user-id">学习 ID: {{uid || 'EDU8821'}}</text>
          </view>
        </block>
        <block wx:else>
          <view class="login-prompt">
            <image class="avatar-placeholder" src="{{defaultAvatar}}" mode="aspectFill"></image>
            <view class="prompt-text">
              <text class="t1">还没有登录</text>
              <text class="t2">登录后可同步学习记录并练习自己的题库</text>
            </view>
            <button class="btn-login-round" bindtap="onLogin">微信登录</button>
          </view>
        </block>
      </view>
    </view>



    <view class="stat-row" wx:if="{{isLogin}}">
      <view class="stat-card">
        <text class="val">{{summary.examCount}}</text>
        <text class="lab">个人题库练习</text>
      </view>
      <view class="stat-card">
        <text class="val">{{summary.passCount}}</text>
        <text class="lab">通过次数</text>
      </view>
      <view class="stat-card">
        <text class="val">{{summary.bestScore}}</text>
        <text class="lab">最高成绩</text>
      </view>
    </view>

    <view class="menu-section">
      <view class="section-header">
        <text class="section-title">常用功能</text>
        <text class="section-subtitle">管理题库、复盘错题和账号数据</text>
      </view>
      <view class="menu-group">
        <view class="menu-item console-item" bindtap="goToCreatorConsole" hover-class="menu-item-hover">
          <view class="item-left">
            <image class="admin-icon menu-admin-icon" src="/assets/admin-logo.png" mode="aspectFill"></image>
            <view class="menu-text-block">
              <text class="menu-title">个人题库后台</text>
              <text class="menu-tip">电脑端维护题库，小程序扫码登录</text>
            </view>
          </view>
          <view class="item-right">
            <text class="menu-status">{{consoleStatusText}}</text>
            <view class="arrow"></view>
          </view>
        </view>

        <view class="menu-item" bindtap="goToStudyReport" hover-class="menu-item-hover">
          <view class="item-left">
            <view class="icon-wrap report"></view>
            <view class="menu-text-block">
              <text class="menu-title">学习报告</text>
              <text class="menu-tip">查看成绩趋势、通过率和薄弱题库</text>
            </view>
          </view>
          <view class="item-right">
            <view class="arrow"></view>
          </view>
        </view>

        <view class="menu-item" bindtap="goToWrongBook" hover-class="menu-item-hover">
          <view class="item-left">
            <view class="icon-wrap wrong"></view>
            <view class="menu-text-block">
              <text class="menu-title">错题本</text>
              <text class="menu-tip">按题库整理错题，集中巩固薄弱点</text>
            </view>
          </view>
          <view class="item-right">
            <view class="arrow"></view>
          </view>
        </view>
        <view class="menu-item" bindtap="goToQuestionSearch" hover-class="menu-item-hover">
          <view class="item-left">
            <view class="icon-wrap search"></view>
            <view class="menu-text-block">
              <text class="menu-title">题目搜索</text>
              <text class="menu-tip">快速查找题干、解析和选项内容</text>
            </view>
          </view>
          <view class="item-right">
            <view class="arrow"></view>
          </view>
        </view>
        <view class="menu-item" bindtap="goToAccountManage" hover-class="menu-item-hover">
          <view class="item-left">
            <view class="icon-wrap security"></view>
            <view class="menu-text-block">
              <text class="menu-title">账号与数据</text>
              <text class="menu-tip">查看登录资料和数据管理入口</text>
            </view>
          </view>
          <view class="item-right">
            <view class="arrow"></view>
          </view>
        </view>
      </view>
    </view>

    <view class="footer-spacer"></view>
  </view>

  <view class="console-mask" wx:if="{{consoleDialogVisible}}" bindtap="closeConsoleDialog">
    <view class="console-panel" catchtap="noop">
      <view class="console-close" bindtap="closeConsoleDialog" hover-class="console-close-hover" aria-label="关闭"></view>
      <view class="console-hero">
        <image class="console-panel-icon" src="/assets/admin-logo.png" mode="aspectFill"></image>
      </view>
      <text class="console-panel-title">个人题库后台</text>
      <text class="console-panel-desc">先在电脑浏览器打开后台地址，再回到小程序扫码确认。</text>

      <view class="console-steps">
        <view class="console-step">
          <text class="step-index">1</text>
          <text class="step-text">电脑打开</text>
        </view>
        <view class="console-step-line"></view>
        <view class="console-step">
          <text class="step-index">2</text>
          <text class="step-text">扫码确认</text>
        </view>
      </view>

      <view class="console-url-card" bindtap="copyConsoleUrl" hover-class="console-url-card-hover">
        <view class="url-card-head">
          <text class="url-label">电脑端地址</text>
          <text class="url-action">点击复制</text>
        </view>
        <text class="url-value">{{consoleUrl}}</text>
      </view>

      <view class="console-actions">
        <button class="console-primary-btn" bindtap="openScanLoginFromDialog" hover-class="console-button-hover">去扫码登录</button>
        <button class="console-secondary-btn" bindtap="copyConsoleUrl" hover-class="console-button-hover">复制地址</button>
      </view>
    </view>
  </view>
</view>
