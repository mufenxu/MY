<view class="container exam-page">
  <view class="custom-nav" style="padding-top: {{capsuleTop}}px;">
    <view class="nav-title" style="height: {{capsuleHeight}}px; line-height: {{capsuleHeight}}px;">
      {{title}}
    </view>
  </view>

  <view wx:if="{{loading || (attemptInitializationPending && !attemptInitializationError)}}" style="margin-top: {{navBarHeight}}px; padding: 40rpx 0;">
    <skeleton type="exam"></skeleton>
  </view>

  <view
    class="attempt-error-state"
    wx:if="{{!loading && attemptInitializationError}}"
    style="padding-top: {{navBarHeight}}px;"
  >
    <text class="attempt-error-title">考试暂时无法开始</text>
    <text class="attempt-error-message">{{attemptInitializationError}}</text>
    <view class="attempt-error-actions">
      <button
        class="attempt-retry-button"
        bindtap="onRetryAttemptInitialization"
        loading="{{attemptInitializationPending}}"
        disabled="{{attemptInitializationPending}}"
      >重新加载</button>
      <button
        class="attempt-exit-button"
        bindtap="onExitAttemptInitialization"
        disabled="{{attemptInitializationPending}}"
      >返回</button>
    </view>
  </view>

  <view
    class="main-content"
    wx:if="{{!loading && !attemptInitializationPending && !attemptInitializationError && totalCount > 0}}"
    style="height: calc(100vh - {{navBarHeight}}px); margin-top: {{navBarHeight}}px; display: flex; flex-direction: column;"
  >
    <view class="header-bar">
      <view class="progress-info">
        <text class="current-index">{{currentIndex + 1}}</text>
        <text class="total-count">/ {{totalCount}}</text>
        <text class="timer" wx:if="{{timeLeft > 0}}">⏱ {{timerStr}}</text>
      </view>

      <view class="actions">
        <view class="btn-sheet" bindtap="onToggleAnswerSheet">
          <view class="sheet-icon">
            <view class="rect"></view>
            <view class="rect"></view>
            <view class="rect"></view>
            <view class="rect"></view>
          </view>
          <text>答题卡</text>
        </view>
      </view>
    </view>

    <view class="recite-overview" wx:if="{{mode === 'recite'}}">
      <text class="overview-item">已掌握 {{reciteKnownCount}}</text>
      <text class="overview-item">待复习 {{recitePendingCount}}</text>
      <text class="overview-item">今日复习 {{reciteReviewedCount}}</text>
    </view>

    <progress
      percent="{{mode === 'recite' ? (reciteKnownCount / totalCount * 100) : ((currentIndex + 1) / totalCount * 100)}}"
      stroke-width="3"
      activeColor="#3B82F6"
      backgroundColor="#E7ECF3"
      class="progress-line"
    />

    <swiper
      class="question-swiper"
      current="{{swiperCurrent}}"
      disable-touch="{{mode === 'recite'}}"
      bindchange="onSwiperChange"
      duration="300"
      style="flex: 1; width: 100%;"
    >
      <swiper-item wx:for="{{swiperQuestions}}" wx:key="originalIndex">
        <scroll-view scroll-y class="swiper-scroll-view" style="height: 100%;">
          <view class="question-area">
            <question-card
              question="{{item.question}}"
              showAnalysis="{{item.originalIndex === currentIndex ? isAnalysisVisible : false}}"
              userAnswer="{{answers[item.question._id] || []}}"
              canUseAiAnalysis="{{canUseAiAnalysis}}"
              canGenerateAiAnalysis="{{canGenerateAiAnalysis}}"
              aiAnalysis="{{aiAnalysisByQuestionId[item.question._id] || ''}}"
              aiAnalysisLoading="{{aiAnalysisLoadingByQuestionId[item.question._id] || false}}"
              bind:change="onAnswerChange"
              bind:ai-analysis="onAiAnalysisRequest"
            />
          </view>
          <view class="footer-spacer" style="height: {{footerSpacerHeight}}px;"></view>
        </scroll-view>
      </swiper-item>
    </swiper>
  </view>

  <view class="footer-bar" wx:if="{{!loading && !attemptInitializationPending && !attemptInitializationError}}" style="padding-bottom: {{footerBottomPadding}}px;">
    <view class="btn-group recite-group" wx:if="{{mode === 'recite'}}">
      <button class="btn-nav btn-reveal" bindtap="onToggleAnalysis">
        {{isAnalysisVisible ? '隐藏答案' : '显示答案'}}
      </button>
      <button class="btn-confirm btn-known" bindtap="onReciteMark" data-level="known">会了</button>
      <button class="btn-confirm btn-fuzzy" bindtap="onReciteMark" data-level="fuzzy">模糊</button>
      <button class="btn-confirm btn-unknown" bindtap="onReciteMark" data-level="unknown">不会</button>
    </view>

    <view class="btn-group" wx:else>
      <button class="btn-nav btn-prev {{currentIndex === 0 ? 'disabled' : ''}}" bindtap="onPrev" disabled="{{currentIndex === 0}}">上一题</button>

      <button
        class="btn-confirm"
        wx:if="{{mode === 'practice' && questions[currentIndex].type === 'multiple' && !isAnalysisVisible}}"
        bindtap="onConfirmAnswer"
      >确认作答</button>

      <button
        class="btn-submit"
        wx:elif="{{currentIndex === totalCount - 1}}"
        bindtap="onSubmit"
        loading="{{isSubmitting}}"
        disabled="{{isSubmitting}}"
      >{{isSubmitting ? '提交中' : '提交试卷'}}</button>
      <button class="btn-nav btn-next" wx:else bindtap="onNext">下一题</button>
    </view>
  </view>

  <view class="answer-sheet-mask {{showAnswerSheet ? 'visible' : ''}}" bindtap="onToggleAnswerSheet"></view>
  <view class="answer-sheet {{showAnswerSheet ? 'visible' : ''}}">
    <view class="sheet-header">
      <view class="sheet-close-btn" bindtap="onToggleAnswerSheet">×</view>
      <text class="sheet-title">答题卡</text>
      <view class="sheet-legend" wx:if="{{mode !== 'recite'}}">
        <view class="legend-item"><view class="legend-dot current"></view><text>当前</text></view>
        <view class="legend-item"><view class="legend-dot answered"></view><text>已答</text></view>
        <view class="legend-item"><view class="legend-dot pending"></view><text>未答</text></view>
      </view>
      <view class="recite-legend" wx:if="{{mode === 'recite'}}">
        <text class="legend-item known">会了</text>
        <text class="legend-item fuzzy">模糊</text>
        <text class="legend-item unknown">不会</text>
      </view>
    </view>
    <scroll-view scroll-y class="sheet-content">
      <block wx:for="{{groupedQuestions}}" wx:key="type" wx:for-item="group">
        <view class="type-section">
          <view class="type-header">
            <text class="type-name">{{group.typeName}}</text>
            <text class="type-count">（{{group.items.length}}题）</text>
          </view>
          <view class="grid">
            <view
              class="grid-item {{item.originalIndex === currentIndex ? 'current' : ''}} {{mode === 'recite' ? (reciteMasteryClassMap[item.questionId] || '') : (answers[item.questionId] ? 'answered' : '')}}"
              wx:for="{{group.items}}"
              wx:key="originalIndex"
              bindtap="onJumpToQuestion"
              data-index="{{item.originalIndex}}"
            >
              {{item.originalIndex + 1}}
            </view>
          </view>
        </view>
      </block>
    </scroll-view>
  </view>

  <custom-modal
    show="{{mode !== 'recite' && !attemptInitializationError && showResumeModal}}"
    title="提示"
    content="检测到云端未完成的进度，是否继续？"
    confirmText="继续"
    cancelText="重新开始"
    bind:confirm="onResumeConfirm"
    bind:cancel="onResumeCancel"
  />
</view>
