{
  "name": "@my-platform/admin-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "cross-env NODE_ENV=development node --watch src/server.js",
    "dev:web": "vite --host 127.0.0.1 --port 5180",
    "start": "cross-env NODE_ENV=production node src/server.js",
    "build": "vite build",
    "test": "node --test",
    "check": "npm test && npm run build",
    "password": "node scripts/hash-password.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@my-platform/platform-auth": "file:../../packages/platform-auth",
    "compression": "^1.8.1",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.1.0",
    "lucide-react": "^1.25.0",
    "mongodb": "^7.5.0",
    "prom-client": "^15.1.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "vite": "^7.2.4"
  }
}
