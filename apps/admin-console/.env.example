PLATFORM_HOST=127.0.0.1
PLATFORM_PORT=8788
PLATFORM_TRUST_PROXY=false
PLATFORM_PUBLIC_ORIGIN=https://admin.example.com

# Development defaults to disabled authentication. Production always requires it.
PLATFORM_AUTH_DISABLED=false
PLATFORM_ADMIN_USERNAME=admin
PLATFORM_ADMIN_PASSWORD_HASH=scrypt$replace_with_generated_value
PLATFORM_SESSION_SECRET=replace_with_at_least_32_random_characters
PLATFORM_SESSION_TTL_HOURS=12

PLATFORM_SERVICE_TIMEOUT_MS=8000
# PLATFORM_CONFIG_PATH=C:\path\to\platform.config.json
