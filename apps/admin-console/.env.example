PLATFORM_HOST=127.0.0.1
PLATFORM_PORT=8788
PLATFORM_TRUST_PROXY=false
PLATFORM_PUBLIC_ORIGIN=https://admin.example.com

# Development defaults to disabled authentication. Production always requires it.
PLATFORM_AUTH_DISABLED=false
PLATFORM_ADMIN_USERNAME=admin
PLATFORM_ADMIN_PASSWORD_HASH=scrypt$replace_with_generated_value
PLATFORM_SESSION_SECRET=replace_with_at_least_32_random_characters
PLATFORM_AUTH_ENCRYPTION_KEY=replace_with_base64url_32_byte_key
PLATFORM_INTERNAL_AUTH_PRIVATE_KEY=replace_with_ed25519_pkcs8_base64url
PLATFORM_INTERNAL_AUTH_PUBLIC_KEY=replace_with_ed25519_spki_base64url
PLATFORM_SESSION_TTL_HOURS=12
PLATFORM_SESSION_IDLE_MINUTES=30
PLATFORM_REQUIRE_MFA=true
PLATFORM_MONGODB_URI=mongodb://127.0.0.1:27017/platform_app
PLATFORM_METRICS_TOKEN=replace_with_at_least_32_random_characters

# Adaptive bot verification is enabled only when both values are configured.
PLATFORM_TURNSTILE_SITE_KEY=
PLATFORM_TURNSTILE_SECRET_KEY=
PLATFORM_WEBAUTHN_RP_NAME=MY Platform
PLATFORM_WEBAUTHN_RP_ID=admin.example.com

PLATFORM_SERVICE_TIMEOUT_MS=8000
# PLATFORM_CONFIG_PATH=C:\path\to\platform.config.json
