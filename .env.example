# =============================================================================
# 使用说明
# 1. 将本文件复制为 .env，再修改 .env；不要直接修改或提交真实密钥。
# 2. 所有包含 replace_with、example.com、xxxxxxxx 的值都必须替换，不能原样使用。
# 3. 生成通用随机密钥：
#    node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
# 4. .env 包含密码和密钥，禁止提交到 Git 或发送到公开聊天中。
# =============================================================================

# 所有容器使用中国标准时间。
# TZ：容器时区，国内服务器保持 Asia/Shanghai 即可。
TZ=Asia/Shanghai

# =============================================================================
# 阿里云容器镜像
# 以下地址已经配置完成，通常不需要修改。
# =============================================================================
# ACR_REGISTRY：阿里云容器镜像仓库域名，仅用于记录和登录仓库。
ACR_REGISTRY=crpi-ijf5w3rczq2vwnig.cn-beijing.personal.cr.aliyuncs.com
# MONGODB_IMAGE：MongoDB 7 镜像地址，已经迁移到阿里云。
MONGODB_IMAGE=crpi-ijf5w3rczq2vwnig.cn-beijing.personal.cr.aliyuncs.com/mufenxu/my:mongodb-7.0
# PLATFORM_API_IMAGE：统一管理中心和主要后端镜像地址。
PLATFORM_API_IMAGE=crpi-ijf5w3rczq2vwnig.cn-beijing.personal.cr.aliyuncs.com/mufenxu/my:platform-api-latest
# CAMPUS_SERVICE_IMAGE：校园服务镜像地址。
CAMPUS_SERVICE_IMAGE=crpi-ijf5w3rczq2vwnig.cn-beijing.personal.cr.aliyuncs.com/mufenxu/my:campus-service-latest
# IOT_SERVICE_IMAGE：IoT 和 MQTT 设备管理服务镜像地址。
IOT_SERVICE_IMAGE=crpi-ijf5w3rczq2vwnig.cn-beijing.personal.cr.aliyuncs.com/mufenxu/my:iot-service-latest

# =============================================================================
# 监听地址、端口和公网域名
# 127.0.0.1 表示只允许服务器本机和反向代理访问，建议保持不变。
# PUBLIC_ORIGIN 必须填写完整网址（包含 https://，不要在末尾添加路径）。
# HOSTS 只填写域名，不要包含 http://、https:// 或路径；多个域名用英文逗号分隔。
# =============================================================================
# PLATFORM_BIND_ADDRESS：统一后端绑定地址；127.0.0.1 表示只允许服务器本机访问。
PLATFORM_BIND_ADDRESS=127.0.0.1
# PLATFORM_API_PORT：统一后端端口，已经按统一号段固定为 22100。
PLATFORM_API_PORT=22100
# PLATFORM_PUBLIC_ORIGIN：统一管理中心的公网 HTTPS 地址，必须替换示例域名。
PLATFORM_PUBLIC_ORIGIN=https://pxyb.cn
# CORE_HOSTS：综合小程序后端使用的域名，不包含协议和路径。
CORE_HOSTS=xcx.example.com
# EXAM_HOSTS：考试学习后端使用的域名，不包含协议和路径。
EXAM_HOSTS=exam.example.com
# NOTIFY_HOSTS：企业微信通知接口使用的域名，不包含协议和路径。
NOTIFY_HOSTS=notify.example.com
# CORE_TRUST_PROXY / EXAM_TRUST_PROXY: keep 1 behind the platform reverse proxy; use 0 for direct exposure.
CORE_TRUST_PROXY=1
EXAM_TRUST_PROXY=1

# CAMPUS_BIND_ADDRESS：校园服务绑定地址；建议保持 127.0.0.1，由反向代理访问。
CAMPUS_BIND_ADDRESS=127.0.0.1
# CAMPUS_PORT：校园服务端口，已经按统一号段固定为 22101。
CAMPUS_PORT=22101

# IOT_BIND_ADDRESS：IoT 服务绑定地址；建议保持 127.0.0.1，由反向代理访问。
IOT_BIND_ADDRESS=127.0.0.1
# IOT_PORT：IoT 服务端口，已经按统一号段固定为 22102。
IOT_PORT=22102
# IOT_PUBLIC_ORIGIN：允许访问 IoT 管理页面的公网来源；单域名部署填写统一管理中心地址，独立域名可用英文逗号追加。
IOT_PUBLIC_ORIGIN=https://pxyb.cn

# =============================================================================
# MongoDB 数据库
# 用户名可以修改；密码必须替换为随机强密码。
# 密码会被写入 MongoDB 连接网址，只能使用英文字母、数字、短横线和下划线等 URL 安全字符。
# =============================================================================
# MONGO_ROOT_USERNAME：MongoDB 超级管理员用户名，可以自行修改。
MONGO_ROOT_USERNAME=platform_admin
# MONGO_ROOT_PASSWORD：MongoDB 超级管理员强密码，必须替换占位值并妥善备份。
MONGO_ROOT_PASSWORD=replace_with_url_safe_random_password
MONGODB_BIND_ADDRESS=127.0.0.1
MONGODB_PORT=27017
# MONGO_REPLICA_SET_KEY：MongoDB 副本集内部认证密钥，使用标准 Base64 随机值。
# 生成命令：node -e "console.log(require('node:crypto').randomBytes(48).toString('base64'))"
MONGO_REPLICA_SET_KEY=replace_with_base64_replica_set_key
# 每个服务使用独立数据库账号。密码必须是 URL 安全随机值，不要复用 root 密码。
MONGO_PLATFORM_USERNAME=platform_app
MONGO_PLATFORM_PASSWORD=replace_with_url_safe_platform_db_password
MONGO_CORE_USERNAME=core_app
MONGO_CORE_PASSWORD=replace_with_url_safe_core_db_password
MONGO_EXAM_USERNAME=exam_app
MONGO_EXAM_PASSWORD=replace_with_url_safe_exam_db_password
MONGO_CAMPUS_USERNAME=campus_app
MONGO_CAMPUS_PASSWORD=replace_with_url_safe_campus_db_password
MONGO_IOT_USERNAME=iot_app
MONGO_IOT_PASSWORD=replace_with_url_safe_iot_db_password

# =============================================================================
# 统一管理中心管理员
# 生成管理员密码哈希：npm run password -- "你的至少十位强密码"
# 将命令输出完整粘贴到 PLATFORM_ADMIN_PASSWORD_HASH，并保留外层单引号。
# PLATFORM_SESSION_SECRET 使用上方“生成通用随机密钥”命令生成。
# 会话有效期单位为小时，默认 12 小时。
# =============================================================================
# PLATFORM_ADMIN_USERNAME：统一管理中心登录用户名。
PLATFORM_ADMIN_USERNAME=admin
# PLATFORM_ADMIN_PASSWORD_HASH：统一管理员密码的 scrypt 哈希，不是明文密码。
PLATFORM_ADMIN_PASSWORD_HASH='scrypt$replace_with_generated_hash'
# PLATFORM_SESSION_SECRET：统一管理中心 Cookie/会话签名密钥，必须使用随机值。
PLATFORM_SESSION_SECRET=replace_with_at_least_32_random_characters
# PLATFORM_INTERNAL_AUTH_PRIVATE_KEY：网关签发内部身份票据的 Ed25519 私钥，只会注入 platform-api；运行 npm run keys:internal 一次生成密钥对。
PLATFORM_INTERNAL_AUTH_PRIVATE_KEY=replace_with_generated_ed25519_private_key
# PLATFORM_INTERNAL_AUTH_PUBLIC_KEY：下游服务验证身份票据的 Ed25519 公钥，必须与上一行私钥为同一密钥对。
PLATFORM_INTERNAL_AUTH_PUBLIC_KEY=replace_with_generated_ed25519_public_key
# PLATFORM_SESSION_TTL_HOURS：统一管理中心登录会话有效小时数。
PLATFORM_SESSION_TTL_HOURS=12
# PLATFORM_METRICS_TOKEN：Prometheus 指标端点 Bearer Token，至少 32 位随机值。
PLATFORM_METRICS_TOKEN=replace_with_at_least_32_random_characters
# PLATFORM_SSO_CORE_USERNAME：统一账号进入综合后台时映射的现有管理员 userId，默认 admin。
PLATFORM_SSO_CORE_USERNAME=admin
# PLATFORM_SSO_EXAM_USERNAME：统一账号进入考试后台时映射的现有管理员用户名，默认 admin。
PLATFORM_SSO_EXAM_USERNAME=admin

# =============================================================================
# 综合小程序后端
# CORE_JWT_SECRET：登录令牌签名密钥，使用通用随机密钥生成命令。
# CORE_ENCRYPTION_KEY：业务数据加密密钥，必须替换为恰好 32 个字符。
# 微信 AppID 和 AppSecret 从微信公众平台的小程序后台获取。
# GH_TOKEN 是 CT8 触发 GitHub Actions、更新 Actions Secrets 的必需凭据；不使用 CT8 时可留空。
# GH_WEBHOOK_SECRET、MQTT_API_KEY 不使用对应功能时可以留空。
# =============================================================================
# CORE_JWT_SECRET：综合小程序登录令牌签名密钥，必须使用随机值。
CORE_JWT_SECRET=replace_with_at_least_32_random_characters
# CORE_ENCRYPTION_KEY：综合业务敏感数据加密密钥，必须为恰好 32 个字符。
CORE_ENCRYPTION_KEY=replace_with_a_32_character_key
# CORE_WECHAT_APP_ID：综合小程序的微信 AppID。
CORE_WECHAT_APP_ID=wx_core_app_id
# CORE_WECHAT_APP_SECRET：综合小程序的微信 AppSecret，必须从微信后台获取。
CORE_WECHAT_APP_SECRET=replace_with_core_app_secret
# GH_TOKEN：GitHub Personal Access Token，需要具备目标仓库 Actions / Secrets 读写权限。
GH_TOKEN=
# GH_OWNER / GH_REPO：CT8 自动化仓库位置；也可用 GH_REPOSITORY=owner/repo 一次配置。
GH_OWNER=Mufenxu
GH_REPO=ct8-login
GH_REPOSITORY=
# GH_WORKFLOW / GH_REF：要触发的 workflow 文件名和分支。
GH_WORKFLOW=ssh-login.yml
GH_REF=main
# GH_WEBHOOK_SECRET：GitHub Webhook 验签密钥；未使用 Webhook 时留空。
GH_WEBHOOK_SECRET=
# MQTT_API_KEY：综合后端调用 IoT API 的密钥；未启用接口鉴权时可以留空。
MQTT_API_KEY=

# =============================================================================
# 考试学习小程序后端
# EXAM_JWT_SECRET：登录令牌签名密钥，使用通用随机密钥生成命令。
# 微信 AppID 和 AppSecret 从考试小程序对应的微信公众平台后台获取。
# EXAM_CORS_ORIGINS：允许访问考试接口的完整 HTTPS 网址，多个网址用英文逗号分隔。
# EXAM_DEFAULT_ADMIN_PASSWORD：仅在首次创建默认管理员时使用；已有管理员时可以留空。
# EXAM_SEED_SAMPLE_DATA：是否写入示例数据，正式环境保持 false。
# SUB2API 三项为可选 AI 接口，不使用时留空。
# =============================================================================
# EXAM_JWT_SECRET：考试小程序登录令牌签名密钥，必须使用随机值。
EXAM_JWT_SECRET=replace_with_at_least_32_random_characters
# EXAM_WECHAT_APP_ID：考试小程序的微信 AppID。
EXAM_WECHAT_APP_ID=wx_exam_app_id
# EXAM_WECHAT_APP_SECRET：考试小程序的微信 AppSecret，必须从微信后台获取。
EXAM_WECHAT_APP_SECRET=replace_with_exam_app_secret
# EXAM_CORS_ORIGINS：允许调用考试接口的完整网址，多个网址用英文逗号分隔。
EXAM_CORS_ORIGINS=https://exam.example.com,https://pxyb.cn
# EXAM_DEFAULT_ADMIN_USERNAME：考试后台首次初始化的管理员用户名。
EXAM_DEFAULT_ADMIN_USERNAME=admin
# EXAM_DEFAULT_ADMIN_DISPLAY_NAME：考试后台管理员显示名称，可使用中文。
EXAM_DEFAULT_ADMIN_DISPLAY_NAME=Super Admin
# EXAM_DEFAULT_ADMIN_PASSWORD：首次创建考试管理员时使用的明文密码；已有账号时留空。
EXAM_DEFAULT_ADMIN_PASSWORD=
# EXAM_SEED_SAMPLE_DATA：是否初始化考试示例数据；正式环境保持 false。
EXAM_SEED_SAMPLE_DATA=false
# Exam MongoDB client tuning. The defaults match the container deployment.
EXAM_MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
EXAM_MONGODB_SOCKET_TIMEOUT_MS=45000
EXAM_MONGODB_MAX_POOL_SIZE=10
# SUB2API_BASE_URL：可选 AI 接口基础地址，不使用时留空。
SUB2API_BASE_URL=
# SUB2API_API_KEY：可选 AI 接口密钥，不使用时留空。
SUB2API_API_KEY=
# SUB2API_MODEL：AI 功能使用的模型名称，仅在配置 SUB2API 时生效。
SUB2API_MODEL=gpt-4o-mini

# =============================================================================
# 企业微信通知服务
# WECOM_CORP_ID、WECOM_AGENT_ID、WECOM_SECRET 从企业微信自建应用后台获取。
# NOTIFY_API_KEY 是其他服务调用通知接口时使用的密钥，使用通用随机密钥生成命令。
# TOKEN_CACHE_MARGIN 是企业微信令牌提前刷新的秒数，默认 120 秒。
# =============================================================================
# WECOM_CORP_ID：企业微信企业 ID，从企业微信管理后台获取。
WECOM_CORP_ID=wwxxxxxxxxxxxxxxxx
# WECOM_AGENT_ID：企业微信自建应用 AgentId，通常为数字。
WECOM_AGENT_ID=1000002
# WECOM_SECRET：企业微信自建应用 Secret，必须替换占位值。
WECOM_SECRET=replace_with_rotated_wecom_secret
# NOTIFY_API_KEY：调用通知服务时使用的 API 密钥，必须使用随机值。
NOTIFY_API_KEY=replace_with_rotated_random_api_key
# TOKEN_CACHE_MARGIN：企业微信 access_token 提前刷新的秒数。
TOKEN_CACHE_MARGIN=120

# =============================================================================
# 校园服务
# 一次生成下面三个安全值：npm --prefix services/campus-service run secrets:generate
# 将输出的三行分别填到对应变量，不能继续使用 replace_with 占位值。
# HGU_DATA_ENCRYPTION_KEY 必须是 32 字节随机数据的 Base64URL 编码，通常为 43 个字符。
# 数据加密密钥启用后必须长期备份；随意更换会导致已有校园会话数据无法解密。
# EXTRA_ALLOWED_SCHOOL_HOSTS 不需要额外学校域名时留空。
# 校园用户、会话和缓存统一保存到 campus_app MongoDB 数据库。
# =============================================================================
# HGU_ADMIN_USERNAME：校园服务管理员登录用户名。
HGU_ADMIN_USERNAME=admin
# PLATFORM_SSO_CAMPUS_USERNAME：统一账号进入校园后台时映射的现有校园管理员用户名，通常与 HGU_ADMIN_USERNAME 相同。
PLATFORM_SSO_CAMPUS_USERNAME=admin
# HGU_ADMIN_PASSWORD：校园服务管理员强密码，必须替换占位值。
HGU_ADMIN_PASSWORD=replace_with_strong_password
# HGU_APP_SESSION_SECRET：校园服务登录会话签名密钥，必须使用随机值。
HGU_APP_SESSION_SECRET=replace_with_at_least_32_random_characters
# HGU_DATA_ENCRYPTION_KEY：校园 Cookie/Token 数据加密密钥，必须为有效的 32 字节随机密钥。
HGU_DATA_ENCRYPTION_KEY=replace_with_32_byte_encryption_key
# HGU_EXTRA_ALLOWED_SCHOOL_HOSTS：额外允许访问的学校域名，多个域名用英文逗号分隔；通常留空。
HGU_EXTRA_ALLOWED_SCHOOL_HOSTS=

# =============================================================================
# IoT / MQTT 服务
# MQTT_URL 填写 MQTT Broker 地址。Linux 服务器无法使用 host.docker.internal 时，改为实际内网 IP 或域名。
# MQTT_USERNAME、MQTT_PASSWORD 根据 Broker 配置填写；未启用认证时可以留空。
# IOT_ADMIN_PASSWORD 必须改为强密码。
# IOT_SESSION_SECRET 使用通用随机密钥生成命令。
# IOT_LOG_HTTP_REQUESTS：1 表示记录 HTTP 请求日志，0 表示关闭。
# =============================================================================
# MQTT_URL：MQTT Broker 连接地址，格式为 mqtt://主机:端口 或 mqtts://主机:端口。
MQTT_URL=mqtt://host.docker.internal:1883
# MQTT_USERNAME：MQTT Broker 用户名；Broker 未启用认证时留空。
MQTT_USERNAME=
# MQTT_PASSWORD：MQTT Broker 密码；Broker 未启用认证时留空。
MQTT_PASSWORD=
# MQTT_CLIENT_ID：本服务连接 Broker 时使用的客户端 ID，同一 Broker 内必须唯一。
MQTT_CLIENT_ID=my-platform-iot-service
# IOT_ADMIN_USERNAME：IoT 管理页面登录用户名。
IOT_ADMIN_USERNAME=admin
# IOT_ADMIN_PASSWORD：IoT 管理页面强密码，必须替换占位值。
IOT_ADMIN_PASSWORD=replace_with_strong_password
# IOT_SESSION_SECRET：IoT 管理页面会话签名密钥，必须使用随机值。
IOT_SESSION_SECRET=replace_with_at_least_32_random_characters
# IOT_LOG_HTTP_REQUESTS：是否记录 HTTP 请求日志；1 为开启，0 为关闭。
IOT_LOG_HTTP_REQUESTS=1

# =============================================================================
# 容器资源上限
# 小内存服务器可以按实际容量调整；默认值适合 4 GiB 以上主机。
# =============================================================================
MONGODB_MEMORY_LIMIT=1g
MONGODB_CPU_LIMIT=2
PLATFORM_MEMORY_LIMIT=1g
PLATFORM_CPU_LIMIT=2
CAMPUS_MEMORY_LIMIT=512m
CAMPUS_CPU_LIMIT=1
IOT_MEMORY_LIMIT=512m
IOT_CPU_LIMIT=1
