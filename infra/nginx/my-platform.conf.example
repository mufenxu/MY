map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
}

upstream my_platform_api {
    server 127.0.0.1:8080;
}

# Configure admin, core, exam, notification and api domains with the same proxy.
server {
    listen 443 ssl http2;
    server_name admin.example.com api.example.com core.example.com exam.example.com notify.example.com;

    location / {
        proxy_pass http://my_platform_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }
}

server {
    listen 443 ssl http2;
    server_name campus.example.com;
    location / {
        proxy_pass http://127.0.0.1:8780;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

server {
    listen 443 ssl http2;
    server_name iot.example.com;
    location / {
        proxy_pass http://127.0.0.1:4066;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }
}
