map $http_upgrade $connection_upgrade {
    default upgrade;
    '' '';
}

upstream my_platform_gateway {
    server 127.0.0.1:22100;
    keepalive 32;
}

# 主入口：一个域名承载统一登录、所有管理后台和规范化 API 路径。
server {
    listen 443 ssl http2;
    server_name pxyb.cn;
    server_tokens off;

    # 请按证书实际位置修改。
    ssl_certificate /etc/nginx/ssl/pxyb.cn/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/pxyb.cn/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # 普通 API 请求保持较小的全局请求体上限；备份传输在下方单独放宽。
    client_max_body_size 32m;

    # Raw gzip backup transfers use the same 5 GiB and 10 minute defaults as
    # PLATFORM_BACKUP_UPLOAD_MAX_BYTES and PLATFORM_BACKUP_TRANSFER_TIMEOUT_MS.
    location ^~ /api/backups/ {
        client_max_body_size 5g;
        client_body_timeout 600s;
        proxy_pass http://my_platform_gateway;
        proxy_http_version 1.1;
        proxy_request_buffering off;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }

    location / {
        proxy_pass http://my_platform_gateway;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        # 覆盖客户端自带的 X-Forwarded-For，避免伪造来源地址绕过登录限流。
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 90s;
        proxy_send_timeout 90s;
    }
}

server {
    listen 80;
    server_name pxyb.cn;
    server_tokens off;
    return 308 https://$host$request_uri;
}
